{
  "name": "@formance/design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless design-system next dev",
    "build": "pnpm registry:build && next build",
    "start": "next start",
    "lint": "eslint --cache",
    "lint:fix": "pnpm run lint --fix",
    "format": "prettier \"**/*.{ts,tsx,md,json}\" --check",
    "format:fix": "prettier \"**/*.{ts,tsx,md,json}\" --write",
    "typecheck": "tsc --noEmit",
    "registry:build": "shadcn build",
    "schemas:validate": "tsx scripts/validate-ledger-schema.ts",
    "extract:operations": "tsx scripts/extract-stack-operations.ts",
    "extract:membership-operations": "tsx scripts/extract-membership-operations.ts",
    "pre-commit": "lint-staged && pnpm run typecheck",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.4",
    "@next/third-parties": "^16.2.6",
    "@shikijs/monaco": "^4.0.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/mdx": "^2.0.13",
    "ajv": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "katex": "^0.17.0",
    "lucide-react": "^1.11.0",
    "mermaid": "^11.15.0",
    "monaco-editor-core": "^0.52.2",
    "next": "^16.2.4",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
